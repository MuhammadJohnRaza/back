{
	"info": {
		"_postman_id": "inv-mgmt-sys-v1",
		"name": "Inventory Management System API",
		"description": "Complete REST API collection for the Laravel Inventory Management System (v1). All protected routes require a Bearer token obtained from POST /api/v1/login.\n\nDefault credentials:\n- Admin: admin@example.com / password\n- Staff: staff@example.com / password",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login (Get Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.collectionVariables.set('token', json.access_token);",
									"    pm.test('Token saved to collection variable', () => pm.expect(json.access_token).to.be.a('string'));",
									"}",
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Response has access_token', () => pm.expect(json).to.have.property('access_token'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "login"]
						},
						"description": "Authenticate user and receive a Bearer token. The test script auto-saves the token to the 'token' collection variable."
					}
				},
				{
					"name": "Get Authenticated User (me)",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/me",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "me"]
						},
						"description": "Returns the currently authenticated user's profile."
					}
				},
				{
					"name": "Logout (Revoke Token)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/logout",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "logout"]
						},
						"description": "Revokes the current Bearer token from the personal_access_tokens table."
					}
				}
			]
		},
		{
			"name": "Categories",
			"item": [
				{
					"name": "List All Categories",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/categories",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "categories"]
						},
						"description": "Paginated list of all categories. Available to all authenticated users."
					}
				},
				{
					"name": "Create Category (Admin Only)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Office Supplies\",\n    \"description\": \"All general office supply items.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/categories",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "categories"]
						},
						"description": "Creates a new category. Returns 403 if authenticated as Staff."
					}
				},
				{
					"name": "Get Single Category",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/categories/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "categories", "1"]
						}
					}
				},
				{
					"name": "Update Category (Admin Only)",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Electronics & Gadgets\",\n    \"description\": \"Updated description for electronics category.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/categories/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "categories", "1"]
						}
					}
				},
				{
					"name": "Delete Category (Admin Only)",
					"request": {
						"method": "DELETE",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/categories/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "categories", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "List Products (Paginated)",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/products?per_page=10",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "products"],
							"query": [
								{"key": "per_page", "value": "10"},
								{"key": "category_id", "value": "", "disabled": true},
								{"key": "search", "value": "", "disabled": true},
								{"key": "low_stock", "value": "true", "disabled": true}
							]
						},
						"description": "Supports query filters: ?search=iphone, ?category_id=1, ?low_stock=true, ?per_page=15"
					}
				},
				{
					"name": "List Low Stock Products",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/products?low_stock=true",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "products"],
							"query": [{"key": "low_stock", "value": "true"}]
						}
					}
				},
				{
					"name": "Create Product (Admin Only)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"category_id\": 1,\n    \"name\": \"Dell XPS 15 Laptop\",\n    \"sku\": \"ELEC-DELL-XPS15\",\n    \"description\": \"Intel Core i7, 16GB RAM, 512GB SSD.\",\n    \"price\": 1299.99,\n    \"quantity\": 20,\n    \"minimum_stock_level\": 5\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/products",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "products"]
						},
						"description": "Returns 201 on success. Returns 403 if authenticated as Staff. Returns 422 on validation error."
					}
				},
				{
					"name": "Get Single Product",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/products/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "products", "1"]
						},
						"description": "Returns full product details including category and stock movement history."
					}
				},
				{
					"name": "Update Product (Admin Only)",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"category_id\": 1,\n    \"name\": \"iPhone 15 Pro Max\",\n    \"sku\": \"ELEC-IPHONE15\",\n    \"description\": \"Updated description.\",\n    \"price\": 1099.99,\n    \"quantity\": 15,\n    \"minimum_stock_level\": 5\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/products/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "products", "1"]
						}
					}
				},
				{
					"name": "Delete Product (Admin Only)",
					"request": {
						"method": "DELETE",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/products/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "products", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Stock Movements",
			"item": [
				{
					"name": "List All Stock Movements",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/stock-movements",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "stock-movements"],
							"query": [
								{"key": "product_id", "value": "", "disabled": true},
								{"key": "type", "value": "in", "disabled": true},
								{"key": "per_page", "value": "15", "disabled": true}
							]
						},
						"description": "Paginated. Supports ?product_id=1 and ?type=in|out filters."
					}
				},
				{
					"name": "Record Stock IN (Restock)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"product_id\": 1,\n    \"type\": \"in\",\n    \"quantity\": 50,\n    \"reason\": \"Stock received from Supplier #42\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/stock-movements",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "stock-movements"]
						},
						"description": "Records an IN movement — increases product stock. Available to both Admin and Staff."
					}
				},
				{
					"name": "Record Stock OUT (Dispatch)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"product_id\": 1,\n    \"type\": \"out\",\n    \"quantity\": 5,\n    \"reason\": \"Customer order #1082 dispatched\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/stock-movements",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "stock-movements"]
						},
						"description": "Records an OUT movement. Returns 422 if quantity exceeds available stock (overdraw protection)."
					}
				},
				{
					"name": "Get Single Stock Movement",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/stock-movements/1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "stock-movements", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Reports",
			"item": [
				{
					"name": "Low Stock Report",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/reports/low-stock",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "reports", "low-stock"]
						},
						"description": "Returns all products where current quantity <= minimum_stock_level (safety stock alert)."
					}
				},
				{
					"name": "Inventory Summary Report",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/reports/summary",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "reports", "summary"]
						},
						"description": "Returns: total_products, total_categories, total_stock_value, low_stock_count, movements_today, top_moving_products."
					}
				}
			]
		}
	]
}
